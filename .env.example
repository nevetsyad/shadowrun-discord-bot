# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# Client and Guild IDs (optional, for development)
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here

# Database Configuration (SQLite)
ConnectionStrings__DefaultConnection=Data Source=/data/shadowrun.db

# Redis Cache Configuration
Cache__Enabled=true
Cache__ConnectionString=redis:6379
Cache__InstanceName=Shadowrun:
Redis__ConnectionString=redis:6379
Redis__InstanceName=Shadowrun:

# Web UI Configuration
WebUI__Port=5000
WebUI__EnableSwagger=true
WebUI__JwtSecret=your_jwt_secret_here_change_in_production

# Application Settings
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000

# Logging
Serilog__WriteTo__0__Name=Console
Serilog__WriteTo__1__Name=File
Serilog__WriteTo__1__Args__path=logs/shadowrun-.log
Serilog__WriteTo__1__Args__rollingInterval=Day

# Health Checks
HealthChecks__Enabled=true

# Bot Settings
Bot__Prefix=!
Bot__MaxCharactersPerUser=5
Bot__MaxDiceRolls=10
