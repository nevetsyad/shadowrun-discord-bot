{
  "Discord": {
    "Token": "${DISCORD_TOKEN}",
    "ClientId": "${CLIENT_ID}",
    "GuildId": "${GUILD_ID}"
  },
  "Database": {
    "ConnectionString": "Data Source=shadowrun.db",
    "EnableSensitiveDataLogging": false
  },
  "Bot": {
    "Prefix": "!",
    "DefaultColor": 5814783,
    "MaxCharactersPerUser": 5,
    "MaxDiceRolls": 10
  },
  "WebUI": {
    "Port": 5000,
    "EnableSwagger": true,
    "JwtSecret": "${JWT_SECRET}"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "Window": "00:01:00"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
